# The production file is /root/.env on the Proxmox host.
TZ=Europe/Amsterdam

# Generate with: openssl rand -hex 32
HOMARR_SECRET_ENCRYPTION_KEY=replace-with-64-hex-characters

# Pi-hole keeps its existing LAN service address after LXC 100 is retired.
PIHOLE_BIND_ADDRESS=192.168.0.100
PIHOLE_DNS_PORT=53
PIHOLE_NTP_PORT=123

# Servarr runs application processes as this numeric account.
SERVARR_PUID=1000
SERVARR_PGID=1000

# Preserve the current VPN identity; never commit the production private key.
SERVARR_VPN_TYPE=wireguard
SERVARR_VPN_SERVICE_PROVIDER=protonvpn
SERVARR_WIREGUARD_PRIVATE_KEY=replace-with-existing-wireguard-private-key
SERVARR_FIREWALL_OUTBOUND_SUBNETS=192.168.0.0/24

# Preserve the existing NZBGet credentials during migration.
NZBGET_USER=replace-with-existing-user
NZBGET_PASS=replace-with-existing-password
