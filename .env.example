# The production file is /root/.env on the Proxmox host.
TZ=Europe/Amsterdam

# Generate with: openssl rand -hex 32
HOMARR_SECRET_ENCRYPTION_KEY=replace-with-64-hex-characters

# Pi-hole keeps its existing LAN service address after LXC 100 is retired.
PIHOLE_BIND_ADDRESS=192.168.0.100
PIHOLE_DNS_PORT=53
PIHOLE_NTP_PORT=123
